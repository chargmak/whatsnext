# TMDB API key — get one at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your-tmdb-api-key

# Supabase project credentials — Project Settings → API in the Supabase dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# CineBot AI — set to "true" ONLY after deploying supabase/functions/cinebot and
# applying its cinebot_usage migration (see supabase/functions/cinebot/README.md).
# When unset/false, CineBot uses its built-in local recommender (TMDB + your
# watchlist) and needs no backend.
VITE_CINEBOT_AI=false

# Web Push VAPID public key — generate with `node scripts/generate-vapid-keys.mjs`.
# This one is safe to expose to the browser; keep the matching private key secret
# (set it as a Supabase edge-function secret). See NOTIFICATIONS_SETUP.md.
# The app ships this same key as a built-in default, so setting it here is only
# needed to rotate/override it.
VITE_VAPID_PUBLIC_KEY=BEiuMR6fPv2p9L2n712L-PTP6Eot_iOiWAk8wrIcZ-54C9SX1aDFfVZZ9VB_-cTzRSuUjjZ3ww5lybJem75rogI
